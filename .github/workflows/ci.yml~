name: JPay CI Pipeline

# 1. KHI NÀO ROBOT CHẠY?
# Robot sẽ kích hoạt mỗi khi có code mới được Push hoặc tạo Pull Request vào nhánh 'main'
on:
  push:
    branches: [ "main" ]
  pull_request:
    branches: [ "main" ]

# 2. ROBOT SẼ LÀM GÌ?
jobs:
  build-and-test:
    name: Build & Run Unit Tests
    runs-on: ubuntu-latest # Thuê một máy ảo dùng hệ điều hành Linux (Ubuntu) mới nhất

    steps:
      # Bước 1: Kéo toàn bộ source code của bạn từ GitHub về máy ảo này
      - name: Checkout Source Code
        uses: actions/checkout@v4

      # Bước 2: Cài đặt môi trường Java 21 lên máy ảo
      - name: Set up JDK 21
        uses: actions/setup-java@v4
        with:
          java-version: '21'
          distribution: 'temurin' # Bản Java chuẩn như file Dockerfile của ta
          cache: maven # Lưu bộ nhớ đệm thư viện để lần sau chạy nhanh hơn

      # Bước 3: Ra lệnh cho Maven chạy toàn bộ Unit Test (WalletServiceTest...)
      - name: Run Unit Tests
        run: mvn test

      # Bước 4: Nếu Test xanh hết, tiến hành đóng gói dự án thành file .jar
      - name: Build Project with Maven
        run: mvn clean package -DskipTests